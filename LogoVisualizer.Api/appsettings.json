{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=LogoVisualizer;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "MasterApp",
    "Audience": "LogoVisualizer",
    "Key": "REPLACE_WITH_MASTER_APP_JWT_KEY_VIA_USER_SECRETS_OR_ENV"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/logos/upload",
        "Period": "1m",
        "Limit": 20
      },
      {
        "Endpoint": "POST:/api/export/png",
        "Period": "1m",
        "Limit": 30
      }
    ]
  },
  "FileStorage": {
    "MaxProductImageSizeBytes": 10485760,
    "MaxLogoFileSizeBytes": 10485760
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
