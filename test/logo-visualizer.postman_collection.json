    "_postman_id": "00000001-0002-0003-0004-000000000005",
    "description": "End-to-end integration tests for the Logo Visualizer backend API.\n\nPrerequisites:\n  1. Docker database running: docker compose up -d\n  2. API running: dotnet run --project LogoVisualizer.Api\n  3. Fixtures created: node setup.js  (done automatically by `npm test`)\n\nRequests run in order. Each folder's requests depend on state set by previous folders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Get dev token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response has a token string', () => {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.have.property('token');",
                  "    pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "    pm.environment.set('token', data.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/dev-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "dev-token"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 Techniques",
      "item": [
        {
          "name": "Get all techniques",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Returns non-empty array', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array').with.length.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Each item has numeric id and non-empty name', () => {",
                  "    pm.response.json().forEach(t => {",
                  "        pm.expect(t).to.have.property('id').that.is.a('number');",
                  "        pm.expect(t).to.have.property('name').that.is.a('string').and.not.empty;",
                  "    });",
                  "});",
                  "",
                  "pm.test('All six expected slug names are present', () => {",
                  "    const names = pm.response.json().map(t => t.name);",
                  "    ['screen_print', 'embroidery', 'pad_print', 'digital_print', 'engraving', 'sublimation']",
                  "        .forEach(slug => pm.expect(names).to.include(slug));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/techniques",
              "host": ["{{baseUrl}}"],
              "path": ["api", "techniques"]
            }
          },
          "response": []
        }
      ]
    },
