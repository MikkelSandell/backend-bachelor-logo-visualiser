                  "pm.test('Response has required product fields', () => {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.have.property('id').that.is.a('number');",
                  "    pm.expect(data).to.have.property('title', 'Newman Test Product');",
                  "    pm.expect(data).to.have.property('imageUrl').that.is.a('string').and.not.empty;",
                  "    pm.expect(data).to.have.property('imageWidth', 100);",
                  "    pm.expect(data).to.have.property('imageHeight', 100);",
                  "    pm.expect(data).to.have.property('printZones').that.is.an('array');",
